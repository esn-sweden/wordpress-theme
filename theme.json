{
	"$schema": "https://schemas.wp.org/trunk/theme.json",
	"version": 3,
	"settings": {
		"color": {
			"palette": [
				{
					"color": "#00aeef",
					"name": "ESN Cyan",
					"slug": "esn-cyan"
				},
				{
					"color": "#ec008c",
					"name": "ESN Magenta",
					"slug": "esn-magenta"
				},
				{
					"color": "#7ac143",
					"name": "ESN Green",
					"slug": "esn-green"
				},
				{
					"color": "#f47b20",
					"name": "ESN Orange",
					"slug": "esn-orange"
				},
				{
					"color": "#2e3192",
					"name": "ESN Dark Blue",
					"slug": "esn-dark-blue"
				},
				{
					"color": "#c51597",
					"name": "Sea Battle Purple #1",
					"slug": "sea-battle-purple-1"
				},
				{
					"color": "#9a269c",
					"name": "Sea Battle Purple #2",
					"slug": "sea-battle-purple-2"
				},
				{
					"color": "#692e9b",
					"name": "Sea Battle Purple #3",
					"slug": "sea-battle-purple-3"
				}
			]
		},
		"spacing": {
			"defaultSpacingSizes": false
		},
		"typography": {
			"defaultFontSizes": false,
			"fontFamilies": [
				{
					"fontFace": [
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/lato/lato-400-normal.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/lato/lato-700-normal.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "italic",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/lato/lato-700-italic.woff2"
							]
						},
						{
							"fontFamily": "Lato",
							"fontStyle": "italic",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/lato/lato-400-italic.woff2"
							]
						}
					],
					"fontFamily": "Lato, sans-serif",
					"name": "Lato",
					"slug": "lato"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"Work Sans\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/work-sans/work-sans-700-normal.woff2"
							]
						}
					],
					"fontFamily": "\"Work Sans\", sans-serif",
					"name": "Work Sans",
					"slug": "work-sans"
				},
				{
					"fontFace": [
						{
							"fontFamily": "\"Kelson Sans\"",
							"fontStyle": "normal",
							"fontWeight": "300",
							"src": [
								"file:./assets/fonts/kelson-sans/kelson-sans-300-normal.otf"
							]
						},
						{
							"fontFamily": "\"Kelson Sans\"",
							"fontStyle": "normal",
							"fontWeight": "400",
							"src": [
								"file:./assets/fonts/kelson-sans/kelson-sans-400-normal.otf"
							]
						},
						{
							"fontFamily": "\"Kelson Sans\"",
							"fontStyle": "normal",
							"fontWeight": "700",
							"src": [
								"file:./assets/fonts/kelson-sans/kelson-sans-700-normal.otf"
							]
						}
					],
					"fontFamily": "\"Kelson Sans\"",
					"name": "Kelson Sans",
					"slug": "kelson-sans"
				}
			],
			"fontSizes": [
				{
					"fluid": {
						"max": "1.85rem",
						"min": "1.39rem"
					}
				},
				{
					"fluid": {
						"max": "2.5rem",
						"min": "1.85rem"
					}
				},
				{
					"fluid": {
						"max": "3.27rem",
						"min": "2.5rem"
					}
				}
			]
		}
	},
	"styles": {
		"blocks": {
			"core/button": {
				"border": {
					"radius": "5px"
				},
				"shadow": "6px 6px 9px rgba(0, 0, 0, 0.2)",
				"variations": {
					"outline": {
						"border": {
							"bottom": {
								"style": "none",
								"width": "0px"
							},
							"left": {
								"style": "none",
								"width": "0px"
							},
							"radius": "5px",
							"right": {
								"style": "none",
								"width": "0px"
							},
							"top": {
								"style": "none",
								"width": "0px"
							}
						},
						"color": {
							"background": "var(--wp--preset--color--base-2)"
						}
					}
				}
			},
			"core/cover": {
				"border": {
					"radius": "20px"
				}
			}
		},
		"css": "/* Extra whitespace around header navigation menu */\n.wp-block-navigation-item__content {\n    padding: 10px\n}\n\n/* Light up in blue when hovering over navigation menu items */\n.wp-block-navigation__responsive-container-open {\n    display: inline-block;\n    margin: 0;\n    padding: 0;\n    background-color: #fff;\n    color: #000;\n    text-decoration: none;\n    border-radius: 50px;\n    transition: background-color 0.3s ease;\n}\n\n.wp-block-navigation-item {\n    display: inline-block;\n    margin: 0;\n    padding: 0;\n    background-color: #007bff;\n    color: #000;\n    text-decoration: none;\n    border-radius: 50px;\n    transition: background-color 0.3s ease, color 0.3s ease;\n}\n\n.wp-block-navigation__submenu-icon {\n    background-color: transparent;\n    transition: background-color 0.3s ease, color 0.3s ease;\n}\n\n.wp-block-navigation-item:hover {\n    background-color: var(--wp--preset--color--esn-cyan);\n    color: #fff;\n}\n\n.wp-block-navigation-link:hover a,\n.wp-block-navigation-submenu:hover a {\n    text-decoration: none;\n}\n\n/* Horizontal bar in ESN colors */\n.esn-color-bar {\n    height: 10px;\n    width: 100%;\n    border-radius: 5px;\n    background: linear-gradient(to right, #00aeef 0%, #00aeef 25%, #ec008c 25%, #ec008c 50%, #7ac143 50%, #7ac143 75%, #f47b20 75%, #f47b20 100%);\n}\n",
		"elements": {
			"button": {
				":focus": {
					"outline": {
						"offset": "2px",
						"style": "dotted",
						"width": "1px"
					}
				},
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--lato)",
					"fontWeight": "400"
				}
			},
			"caption": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--lato)"
				}
			},
			"heading": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--kelson-sans)",
					"fontStyle": "normal"
				}
			},
			"link": {
				"typography": {
					"fontFamily": "var(--wp--preset--font-family--lato)"
				}
			}
		},
		"typography": {
			"fontFamily": "var(--wp--preset--font-family--lato)"
		}
	}
}
